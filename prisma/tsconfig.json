{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "outDir": "../dist/prisma",
    "types": ["node"]
  },
  "include": [
    "seed.ts",
    "cleanup-old-shipping.ts",
    "seed-shipping-system.ts",
    "seed-blog.ts",
    "resetSalesCount.ts",
    "seed-NigitTriple-products.ts",
    "seed-NigitTriple-settings.ts"
  ],
  "exclude": ["node_modules", "../dist"]
}